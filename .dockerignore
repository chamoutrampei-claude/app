# Source control
.git
.gitignore
.gitattributes

# Dependencies (re-installed inside the container)
node_modules
.pnpm-store

# Build artifacts
dist
*.log

# Local env files (use --env-file or platform secrets, never copy them in)
.env
.env.local
.env.*.local

# Dev/test runtime data
.manus-logs
.vite
coverage

# Editor & OS noise
.vscode
.idea
.DS_Store
Thumbs.db

# Project docs not needed at runtime
*.md
references

# But keep these (override above)
!README.md
!DEPLOY.md
# patches/ is needed by pnpm at install time (patchedDependencies)

# Tests aren't needed in the runtime image
**/*.test.ts
**/*.spec.ts
vitest.config.ts

# Other deployment artifacts
Dockerfile
docker-compose.yml
.dockerignore

# Standalone landing (separate deploy)
landing

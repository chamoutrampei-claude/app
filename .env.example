# Trampei — environment variables
# Copy this file to `.env` (local) or set as secrets in your hosting platform.
# All VITE_* vars are baked into the client bundle at BUILD time.
# Everything else is read at runtime.

# -----------------------------------------------------------------------------
# Required for production
# -----------------------------------------------------------------------------

# MySQL connection string. Drizzle ORM reads from here.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://trampei:trampei@localhost:3306/trampei

# OAuth — Manus identity provider for sign-in. Public client config.
# These are exposed to the browser at build time.
VITE_OAUTH_PORTAL_URL=https://oauth.manus.computer
VITE_APP_ID=your-app-id-here

# OAuth — server-side issuer URL used to validate session tokens.
OAUTH_SERVER_URL=https://oauth.manus.computer

# Secret used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-64-char-random-string

# OpenId of the user that should auto-promote to role=admin on first sign-in.
# Leave empty if you don't need bootstrap admin.
OWNER_OPEN_ID=

# -----------------------------------------------------------------------------
# Required for photo uploads (S3 via Manus Forge)
# -----------------------------------------------------------------------------

# Forge serves as a presign proxy in front of S3. Without these,
# storage helpers throw and uploads fall back to data URLs (dev MVP only).
BUILT_IN_FORGE_API_URL=https://forge.manus.computer
BUILT_IN_FORGE_API_KEY=

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------

# Server listen port. Defaults to 3000.
# PORT=3000

# NODE_ENV is set automatically by the `start` script (cross-env).
# Don't override unless you know what you're doing.
# NODE_ENV=production
